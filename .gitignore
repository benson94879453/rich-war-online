# Godot 4+ specific ignores
.godot/
.nomedia

# Godot temporary scene/resource writes
*.tscn*.tmp
*.tres*.tmp
*.res*.tmp

# Headless smoke scripts can generate local Godot script UIDs.
tools/smoke_*.gd.uid
tools/scenarios/*.gd.uid

# Godot-specific ignores
.import/
export.cfg
export_credentials.cfg

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json
